# Core Telegram bot config
BOT_TOKEN=123456789:replace_with_real_bot_token
OWNER_ID=
ALLOWED_CHAT_IDS=
BLOCKED_IDS=
BOT_AUTH_TOTP_SECRET=
BOT_AUTH_TTL_HOURS=168
RATE_LIMIT_S=1.0

# Runtime / container behavior
DOCKER_GID=999
TZ=Asia/Jerusalem
LOG_LEVEL=DEBUG
SHOW_WAN=false
WATCH_PATHS=/,/srv/media
BOT_AUTO_DELETE_MEDIA_HOURS=24

# qBittorrent
QBT_HOST=qbittorrent
QBT_PORT=8080
QBT_USER=admin
QBT_PASS=adminadmin
QBT_TIMEOUT_S=8

# AI provider defaults
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2

# Alerting reachability
ALERT_PING_LAN_TARGETS=
ALERT_PING_WAN_TARGETS=

# Managed devices / WOL / shutdown
# Recommended: use MANAGED_HOSTS_JSON + DEFAULT_MANAGED_HOST
DEFAULT_MANAGED_HOST=
MANAGED_HOSTS_JSON=
WOL_VERIFY_TIMEOUT_S=180
WOL_VERIFY_INTERVAL_S=5

# Legacy single-host WOL compatibility
WOL_TARGET_IP=
WOL_TARGET_MAC=
WOL_BROADCAST_IP=
WOL_PORT=9
WOL_HELPER_IMAGE=python:3.14-alpine
WOL_SSH_TARGET=
WOL_SSH_PORT=22
WOL_SSH_PASSWORD=
WOL_SHUTDOWN_REMOTE_CMD=

# TMDB
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_USER_AGENT=

# Pirate Bay / TPB
TPB_BASE_URL=https://thepiratebay.org
TPB_API_BASE_URL=https://apibay.org
TPB_API_BASE_URLS=
TPB_USER_AGENT=
TPB_COOKIE=
TPB_REFERER=
